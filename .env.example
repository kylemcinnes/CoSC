# --- Public (safe in the browser) ---
NEXT_PUBLIC_SITE_URL=https://churchofsecondchances.ca
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Web Push: generate with `npx web-push generate-vapid-keys` (public key only here)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Server-only (never commit real secrets) ---
# SUPABASE_SERVICE_ROLE_KEY=  # optional: only if you add server routes that bypass RLS

# Owncast: no env var required — set iframe URL in app/(public)/live/page.tsx when stream is ready.

# Resend (Edge Functions): add in Supabase Dashboard → Edge Functions → Secrets
# RESEND_API_KEY=

# Twilio: configure in Supabase Auth → Phone provider (Account SID, Auth Token, Messaging Service SID)

# Future AI sermon pipeline (Whisper + LLM worker): worker reads SUPABASE_SERVICE_ROLE_KEY from its runtime,
# downloads new objects from `sermon-media`, writes transcript JSON + optional `embedding` on `public.sermons`.
